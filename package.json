{
  "name": "discoui-monorepo",
  "private": true,
  "description": "Monorepo for DiscoUI ecosystem",
  "author": "discoui-org",
  "repository": {
    "type": "git",
    "url": "https://github.com/discoui-org/discoui.git"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "pages"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev -w examples/core-demo\" \"npm run dev -w examples/emulator\"",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.0",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
